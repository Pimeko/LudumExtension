{
  "manifest_version": 3,
  "name": "Ludum Extension",
  "version": "1.0",
  "description": "Find the games submitted to the same Ludum Dare edition by the commenters.",
  "content_scripts": [
    {
      "matches": ["https://ldjam.com/events/ludum-dare/*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://api.ldjam.com/*"
  ]
}
